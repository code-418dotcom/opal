# OPAL Platform - Environment Configuration
# Copy this file to .env and fill in your values

# ===== DATABASE =====
# For production: set by Container Apps environment / managed identity
DATABASE_URL=postgresql://postgres:your-password@localhost:5432/opal

# ===== BACKEND SELECTION =====
# Queue: 'azure' (production) or 'database' (local dev)
QUEUE_BACKEND=database

# ===== API SECURITY =====
# Comma-separated list of API keys in format: tenant_keystring
API_KEYS=dev_testkey123

# ===== AZURE =====
# Storage account name (Blob Storage)
STORAGE_ACCOUNT_NAME=
# Service Bus namespace (queue backend)
SERVICEBUS_NAMESPACE=
# Note: In production, services use Managed Identity for auth.
# These are only needed if running locally against Azure resources:
# AZURE_STORAGE_CONNECTION_STRING=
# SERVICEBUS_CONNECTION_STRING=

# ===== AI/ML PROVIDERS =====
# Azure ML endpoint for background removal + scene generation
AML_ENDPOINT_URL=
AML_ENDPOINT_KEY=

# Background Removal: 'rembg' (local, free) or 'azure-vision' (paid)
BACKGROUND_REMOVAL_PROVIDER=rembg
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=

# Image Generation: 'fal' (recommended), 'replicate', or 'huggingface'
IMAGE_GEN_PROVIDER=fal
FAL_API_KEY=
REPLICATE_API_KEY=
HUGGINGFACE_API_KEY=

# Image Upscaling: 'realesrgan' (local, free), 'fal' (paid), or 'replicate' (paid)
UPSCALE_PROVIDER=realesrgan
UPSCALE_ENABLED=true

# Remove.bg (alternative BG removal provider)
REMOVEBG_API_KEY=

# ===== AUTH (Entra External ID) =====
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_ISSUER=

# ===== BILLING =====
MOLLIE_API_KEY=
PUBLIC_BASE_URL=http://localhost:8080

# ===== INTEGRATIONS =====
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SCOPES=read_products,write_products
ENCRYPTION_KEY=

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ===== APPLICATION =====
LOG_LEVEL=INFO
ENV_NAME=development

# ===== FRONTEND =====
VITE_API_URL=http://localhost:8080
VITE_API_KEY=dev_testkey123
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_AUTHORITY=
