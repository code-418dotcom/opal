# OPAL Frontend - Environment Configuration Example
# Copy this file to .env.local and fill in your values

# ===== BACKEND SELECTION =====
# Options: 'azure' or 'supabase'
VITE_BACKEND_TYPE=azure

# ===== AZURE BACKEND (if VITE_BACKEND_TYPE=azure) =====
VITE_API_URL=https://your-azure-web-api.azurecontainerapps.io
VITE_API_KEY=dev_testkey123

# ===== AUTH (Entra External ID) =====
# Get these from: Azure Portal > App registrations > Opal Frontend
VITE_ENTRA_CLIENT_ID=
VITE_ENTRA_AUTHORITY=
