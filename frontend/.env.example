# OPAL Frontend - Environment Configuration Example
# Copy this file to .env.local and fill in your values

# ===== API =====
VITE_API_URL=https://your-azure-web-api.azurecontainerapps.io
VITE_API_KEY=dev_testkey123

# ===== AUTH (Entra External ID) =====
